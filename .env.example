# GitHub personal access token (scopes: public_repo, read:user).
# Consumed by lib/github.ts for the projects list and the Daily Code stat bar.
# When either GITHUB_TOKEN or GITHUB_LOGIN is unset, both fall back to
# content/projects-manual.yml + a static 7-day PRNG stub.
#
# Where it shows up:
#   - `pnpm dev`     → loaded from .env.local on the dev machine.
#   - `pnpm build`   → loaded from .env on the dev machine; baked into the
#                      first ISR render that runs during the build.
#   - `scripts/build.sh <tag>` → forwarded as `docker build --build-arg`.
#   - Runtime in production → injected by Self-Deploy's services/scmlab/.env;
#                              this repo does not configure runtime env.
GITHUB_TOKEN=

# Your GitHub login (e.g. octocat). Required together with GITHUB_TOKEN to
# enable the GraphQL fetch.
GITHUB_LOGIN=
