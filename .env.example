# GitHub personal access token (scopes: public_repo, read:user).
# When either GITHUB_TOKEN or GITHUB_LOGIN is unset, projects + Daily Code bar
# fall back to content/projects-manual.yml + a static 7-day stub.
GITHUB_TOKEN=

# Your GitHub login (e.g. octocat). Required together with GITHUB_TOKEN to
# enable the GraphQL fetch.
GITHUB_LOGIN=

# Host paths bind-mounted into the container in production.
# Local dev can ignore these — defaults below match the in-repo paths.
MEDIA_DIR=./public/media
CONTENT_DIR=./content
